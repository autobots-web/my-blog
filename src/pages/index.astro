---
// src/pages/index.astro
import trendingData from '../data/trending.json';

// Sort posts by date (newest first)
const sortedPosts = [...trendingData].sort((a, b) => 
  new Date(b.date) - new Date(a.date)
);
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Blog</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
        }
        
        .container {
            max-width: 800px;
            margin: 0 auto;
            padding: 2rem;
        }
        
        /* Header */
        .header {
            text-align: center;
            margin-bottom: 3rem;
        }
        
        .header h1 {
            font-size: 3rem;
            color: white;
            margin-bottom: 0.5rem;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.2);
        }
        
        .header p {
            color: rgba(255,255,255,0.9);
            font-size: 1.1rem;
        }
        
        .update-badge {
            display: inline-block;
            background: rgba(255,255,255,0.2);
            padding: 0.25rem 0.75rem;
            border-radius: 20px;
            font-size: 0.8rem;
            margin-top: 1rem;
        }
        
        /* Blog Card */
        .blog-card {
            background: white;
            border-radius: 16px;
            padding: 2rem;
            margin-bottom: 2rem;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }
        
        .blog-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.15);
        }
        
        .blog-title {
            font-size: 1.8rem;
            color: #333;
            margin-bottom: 0.75rem;
            line-height: 1.3;
        }
        
        .blog-meta {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin-bottom: 1.5rem;
            color: #666;
            font-size: 0.9rem;
        }
        
        .blog-date {
            display: flex;
            align-items: center;
            gap: 0.25rem;
        }
        
        .blog-content {
            color: #555;
            line-height: 1.8;
            margin-bottom: 1.5rem;
        }
        
        .read-more {
            display: inline-block;
            color: #667eea;
            text-decoration: none;
            font-weight: 600;
            transition: color 0.3s ease;
        }
        
        .read-more:hover {
            color: #764ba2;
        }
        
        /* Empty State */
        .empty-state {
            background: white;
            border-radius: 16px;
            padding: 4rem 2rem;
            text-align: center;
            color: #666;
        }
        
        .empty-state h2 {
            margin-bottom: 1rem;
            color: #333;
        }
        
        /* Footer */
        .footer {
            text-align: center;
            margin-top: 3rem;
            color: rgba(255,255,255,0.8);
            font-size: 0.9rem;
        }
        
        @media (max-width: 600px) {
            .container {
                padding: 1rem;
            }
            
            .blog-card {
                padding: 1.5rem;
            }
            
            .blog-title {
                font-size: 1.4rem;
            }
            
            .header h1 {
                font-size: 2rem;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>📝 My Blog</h1>
            <p>Thoughts, stories, and ideas</p>
            <div class="update-badge">
                🕐 Last updated: <span id="update-time"></span>
            </div>
        </div>
        
        {
            sortedPosts.length === 0 ? (
                <div class="empty-state">
                    <h2>✨ No posts yet</h2>
                    <p>Check back soon for new content!</p>
                </div>
            ) : (
                sortedPosts.map((post) => (
                    <article class="blog-card">
                        <h2 class="blog-title">{post.title}</h2>
                        <div class="blog-meta">
                            <span class="blog-date">
                                📅 {post.date || new Date().toISOString().split('T')[0]}
                            </span>
                            {post.score && <span>⭐ {post.score}</span>}
                        </div>
                        <div class="blog-content">
                            {post.content}
                        </div>
                        {post.url && (
                            <a href={post.url} class="read-more" target="_blank">
                                Read full article →
                            </a>
                        )}
                    </article>
                ))
            )
        }
        
        <div class="footer">
            <p>© 2026 My Blog. All rights reserved.</p>
        </div>
    </div>
    
    <script>
        document.getElementById('update-time').innerText = new Date().toLocaleString();
    </script>
</body>
</html>