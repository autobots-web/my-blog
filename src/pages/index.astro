---
// src/pages/index.astro
import trendingData from '../data/trending.json';

// Get only the latest story
const story = trendingData.length > 0 ? trendingData[0] : null;
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Daily stories and insights">
    <title>{story ? story.title : 'Daily Story'} | Daily Story Blog</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Georgia', 'Times New Roman', Times, serif;
            background: #ffffff;
            color: #1a1a1a;
            line-height: 1.5;
        }
        
        /* Top Navigation Bar */
        .top-nav {
            background: #000000;
            padding: 0.8rem 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 1rem;
        }
        
        .logo {
            color: white;
            font-size: 1.3rem;
            font-weight: bold;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            text-decoration: none;
        }
        
        .nav-links {
            display: flex;
            gap: 1.5rem;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        }
        
        .nav-links a {
            color: #cccccc;
            text-decoration: none;
            font-size: 0.85rem;
            transition: color 0.2s;
        }
        
        .nav-links a:hover {
            color: white;
        }
        
        /* Main Layout: 2 Columns */
        .main-container {
            max-width: 1280px;
            margin: 0 auto;
            padding: 2rem;
            display: grid;
            grid-template-columns: 1fr 300px;
            gap: 3rem;
        }
        
        /* Article Content */
        .article-content {
            min-width: 0;
        }
        
        /* Ad Box Styling */
        .ad-box {
            background: #f5f5f5;
            border: 1px solid #e0e0e0;
            border-radius: 8px;
            padding: 1.5rem;
            text-align: center;
            margin: 2rem 0;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        }
        
        .ad-label {
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: #999;
            margin-bottom: 0.75rem;
        }
        
        .ad-placeholder {
            background: #e8e8e8;
            padding: 2rem;
            border-radius: 4px;
            color: #666;
            font-size: 0.8rem;
        }
        
        /* Sidebar Ad Boxes */
        .sidebar-ad {
            background: #f5f5f5;
            border: 1px solid #e0e0e0;
            border-radius: 8px;
            padding: 1.2rem;
            text-align: center;
            margin-bottom: 2rem;
        }
        
        .sidebar-ad .ad-label {
            margin-bottom: 0.5rem;
        }
        
        .sidebar-ad-placeholder {
            background: #e8e8e8;
            padding: 1.5rem;
            border-radius: 4px;
            color: #666;
            font-size: 0.75rem;
        }
        
        /* Article Header */
        .article-header {
            margin-bottom: 2rem;
            border-bottom: 1px solid #eaeaea;
            padding-bottom: 1.5rem;
        }
        
        .category-tag {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            font-size: 0.75rem;
            text-transform: uppercase;
            color: #0066cc;
            letter-spacing: 1px;
            margin-bottom: 0.75rem;
        }
        
        h1 {
            font-size: 2.5rem;
            font-weight: 700;
            line-height: 1.2;
            margin-bottom: 1rem;
            color: #1a1a1a;
        }
        
        .byline {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            font-size: 0.85rem;
            color: #666;
            margin-bottom: 1rem;
        }
        
        .date {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            font-size: 0.8rem;
            color: #888;
        }
        
        /* Article Body */
        .article-body {
            font-size: 1.1rem;
            line-height: 1.7;
            color: #2c3e50;
        }
        
        .article-body p {
            margin-bottom: 1.5rem;
        }
        
        /* Sidebar */
        .sidebar {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        }
        
        .sidebar h3 {
            font-size: 1rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: #333;
            margin-bottom: 1rem;
            padding-bottom: 0.5rem;
            border-bottom: 2px solid #0066cc;
        }
        
        .popular-post {
            margin-bottom: 1rem;
            padding-bottom: 1rem;
            border-bottom: 1px solid #eee;
        }
        
        .popular-post a {
            text-decoration: none;
            color: #1a1a1a;
            font-weight: 500;
            line-height: 1.4;
        }
        
        .popular-post a:hover {
            color: #0066cc;
        }
        
        .popular-post .post-date {
            font-size: 0.7rem;
            color: #888;
            margin-top: 0.25rem;
        }
        
        /* Empty State */
        .empty-state {
            text-align: center;
            padding: 4rem;
            background: #fafafa;
            border-radius: 12px;
        }
        
        /* Footer */
        .footer {
            background: #f8f8f8;
            margin-top: 3rem;
            padding: 2rem;
            text-align: center;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            font-size: 0.8rem;
            color: #666;
            border-top: 1px solid #eaeaea;
        }
        
        /* Responsive */
        @media (max-width: 900px) {
            .main-container {
                grid-template-columns: 1fr;
                gap: 2rem;
            }
            
            h1 {
                font-size: 1.8rem;
            }
            
            .article-body {
                font-size: 1rem;
            }
            
            .top-nav {
                padding: 0.8rem 1rem;
            }
        }
    </style>
</head>
<body>
    <!-- Top Navigation -->
    <nav class="top-nav">
        <a href="/" class="logo">📰 DAILY STORY</a>
        <div class="nav-links">
            <a href="/">Home</a>
            <a href="#">Archive</a>
            <a href="#">About</a>
            <a href="#">Contact</a>
        </div>
    </nav>
    
    <div class="main-container">
        <!-- Main Article Column -->
        <main class="article-content">
            {!story ? (
                <div class="empty-state">
                    <h2>No story yet</h2>
                    <p>Check back tomorrow for today's story.</p>
                </div>
            ) : (
                <>
                    <!-- Ad Box 1: Top of Article -->
                    <div class="ad-box">
                        <div class="ad-label">ADVERTISEMENT</div>
                        <div class="ad-placeholder">
                            Your Ad Code Here<br>
                            <small>(300x250 or responsive)</small>
                        </div>
                    </div>
                    
                    <article>
                        <div class="article-header">
                            <div class="category-tag">📖 TODAY'S STORY</div>
                            <h1>{story.title}</h1>
                            <div class="byline">By Daily Story Team</div>
                            <div class="date">
                                {story.date 
                                    ? new Date(story.date).toLocaleDateString('en-US', { 
                                        year: 'numeric', 
                                        month: 'long', 
                                        day: 'numeric' 
                                      })
                                    : new Date().toLocaleDateString('en-US', { 
                                        year: 'numeric', 
                                        month: 'long', 
                                        day: 'numeric' 
                                      })
                                }
                            </div>
                        </div>
                        
                        <div class="article-body">
                            <p>{story.content}</p>
                        </div>
                    </article>
                    
                    <!-- Ad Box 2: Middle of Article -->
                    <div class="ad-box">
                        <div class="ad-label">ADVERTISEMENT</div>
                        <div class="ad-placeholder">
                            Your Ad Code Here<br>
                            <small>(300x250 or responsive)</small>
                        </div>
                    </div>
                    
                    <!-- Ad Box 3: After Article -->
                    <div class="ad-box">
                        <div class="ad-label">ADVERTISEMENT</div>
                        <div class="ad-placeholder">
                            Your Ad Code Here<br>
                            <small>(728x90 banner)</small>
                        </div>
                    </div>
                </>
            )}
        </main>
        
        <!-- Sidebar Column with Ads -->
        <aside class="sidebar">
            <!-- Sidebar Ad 1 -->
            <div class="sidebar-ad">
                <div class="ad-label">ADVERTISEMENT</div>
                <div class="sidebar-ad-placeholder">
                    Your Ad Code Here<br>
                    <small>(300x250)</small>
                </div>
            </div>
            
            <h3>Popular Stories</h3>
            <div class="popular-post">
                <a href="#">Previous story from yesterday</a>
                <div class="post-date">March 25, 2026</div>
            </div>
            <div class="popular-post">
                <a href="#">Story from March 24</a>
                <div class="post-date">March 24, 2026</div>
            </div>
            <div class="popular-post">
                <a href="#">Story from March 23</a>
                <div class="post-date">March 23, 2026</div>
            </div>
            
            <!-- Sidebar Ad 2 -->
            <div class="sidebar-ad">
                <div class="ad-label">ADVERTISEMENT</div>
                <div class="sidebar-ad-placeholder">
                    Your Ad Code Here<br>
                    <small>(300x600)</small>
                </div>
            </div>
            
            <!-- Sidebar Ad 3 -->
            <div class="sidebar-ad">
                <div class="ad-label">ADVERTISEMENT</div>
                <div class="sidebar-ad-placeholder">
                    Your Ad Code Here<br>
                    <small>(300x250)</small>
                </div>
            </div>
        </aside>
    </div>
    
    <footer class="footer">
        <p>© 2026 Daily Story Blog. All rights reserved.</p>
        <p style="margin-top: 0.5rem; font-size: 0.7rem;">Powered by daily stories | Updated every day</p>
    </footer>
</body>
</html>