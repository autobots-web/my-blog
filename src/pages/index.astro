---
// src/pages/index.astro
import trendingData from '../data/trending.json';

// Get only the latest/most recent post
const latestPost = trendingData.length > 0 ? trendingData[0] : null;
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Daily Story</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Georgia', 'Times New Roman', Times, serif;
            background: #faf9f8;
            color: #1a1a1a;
            line-height: 1.6;
        }
        
        .container {
            max-width: 720px;
            margin: 0 auto;
            padding: 2rem 1.5rem;
        }
        
        /* Header - Clean & Simple */
        .site-header {
            text-align: center;
            padding: 2rem 0 1rem 0;
            border-bottom: 1px solid #eae6df;
            margin-bottom: 3rem;
        }
        
        .site-title {
            font-size: 2rem;
            font-weight: 400;
            letter-spacing: -0.5px;
            color: #2c3e50;
        }
        
        .site-title a {
            text-decoration: none;
            color: #2c3e50;
        }
        
        .site-description {
            color: #7f8c8d;
            font-size: 0.9rem;
            margin-top: 0.5rem;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        }
        
        .date-badge {
            text-align: center;
            margin-bottom: 2rem;
        }
        
        .date-badge span {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            background: #eae6df;
            padding: 0.3rem 0.8rem;
            border-radius: 20px;
            color: #5e5a55;
        }
        
        /* Story Content */
        .story-title {
            font-size: 2.8rem;
            font-weight: 700;
            line-height: 1.2;
            margin-bottom: 1.5rem;
            color: #1a1a1a;
            text-align: left;
        }
        
        .story-meta {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            font-size: 0.85rem;
            color: #8e8e8e;
            margin-bottom: 2rem;
            padding-bottom: 1rem;
            border-bottom: 1px solid #eae6df;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        
        .story-content {
            font-size: 1.2rem;
            color: #2c3e50;
        }
        
        .story-content p {
            margin-bottom: 1.5rem;
        }
        
        /* Empty State */
        .empty-state {
            text-align: center;
            padding: 4rem 2rem;
            background: #fff;
            border-radius: 12px;
            border: 1px solid #eae6df;
        }
        
        .empty-state h2 {
            font-size: 1.5rem;
            font-weight: 400;
            margin-bottom: 1rem;
            color: #2c3e50;
        }
        
        .empty-state p {
            color: #7f8c8d;
        }
        
        /* Footer */
        .site-footer {
            margin-top: 4rem;
            padding-top: 2rem;
            text-align: center;
            font-size: 0.8rem;
            color: #b0a8a0;
            border-top: 1px solid #eae6df;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        }
        
        /* Responsive */
        @media (max-width: 600px) {
            .container {
                padding: 1rem;
            }
            
            .story-title {
                font-size: 2rem;
            }
            
            .story-content {
                font-size: 1rem;
            }
            
            .site-title {
                font-size: 1.5rem;
            }
        }
        
        /* Simple animations */
        .story-content {
            animation: fadeIn 0.6s ease;
        }
        
        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <header class="site-header">
            <h1 class="site-title">
                <a href="/">Daily Story</a>
            </h1>
            <div class="site-description">One story, every day</div>
        </header>
        
        <div class="date-badge">
            <span>
                {
                    latestPost && latestPost.date 
                        ? new Date(latestPost.date).toLocaleDateString('en-US', { 
                            weekday: 'long', 
                            year: 'numeric', 
                            month: 'long', 
                            day: 'numeric' 
                          })
                        : new Date().toLocaleDateString('en-US', { 
                            weekday: 'long', 
                            year: 'numeric', 
                            month: 'long', 
                            day: 'numeric' 
                          })
                }
            </span>
        </div>
        
        {
            !latestPost ? (
                <div class="empty-state">
                    <h2>✨ No story yet</h2>
                    <p>Check back tomorrow for today's story.</p>
                </div>
            ) : (
                <article class="story-content">
                    <h1 class="story-title">{latestPost.title}</h1>
                    <div class="story-meta">
                        <span>📖 Today's story</span>
                        <span>⭐ Featured</span>
                    </div>
                    <div class="story-content">
                        <p>{latestPost.content}</p>
                    </div>
                </article>
            )
        }
        
        <footer class="site-footer">
            <p>A daily story • Updated every day</p>
        </footer>
    </div>
</body>
</html>